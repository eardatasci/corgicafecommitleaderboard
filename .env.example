# --- Database ---------------------------------------------------------
# SQLite for local dev. On deploy, point at a free Postgres (Neon/Supabase)
# and change the provider in prisma/schema.prisma to "postgresql".
DATABASE_URL="file:./dev.db"

# --- GitHub OAuth App (free) -------------------------------------------
# Create at https://github.com/settings/applications/new
#   Homepage URL:            http://localhost:3000
#   Authorization callback:  http://localhost:3000/auth/github/callback
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# --- Secrets ------------------------------------------------------------
# 32-byte hex key for encrypting GitHub tokens at rest (also derives the
# session-cookie signing key). Generate: openssl rand -hex 32
TOKEN_ENC_KEY=""

# --- Presence ------------------------------------------------------------
# Comma-separated public IP(s) of the cafe router.
CORGI_IPS="203.0.113.7"

# Preferred: a header the edge proxy overwrites with the real client IP
# (verified unspoofable). On Render/Cloudflare use "true-client-ip".
# When set, this wins over X-Forwarded-For hop counting below.
# TRUSTED_IP_HEADER="true-client-ip"

# Fallback: rightmost X-Forwarded-For entries appended by proxies you control.
TRUSTED_PROXY_HOPS="1"

# Local dev only: pretend every heartbeat comes from this IP.
# Set it to one of CORGI_IPS to simulate being in the cafe. NEVER set in prod.
# DEV_FAKE_IP="203.0.113.7"

# Public base URL of the app (OAuth redirects).
BASE_URL="http://localhost:3000"

# --- Tuning (defaults shown) ---------------------------------------------
HEARTBEAT_TIMEOUT_MIN="5"
SESSION_POLL_MIN="3"
